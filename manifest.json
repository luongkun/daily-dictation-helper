{
  "manifest_version": 3,
  "name": "Trợ lí của Lương",
  "short_name": "Trợ lí của Lương",
  "version": "1.3.1",
  "description": "Tự động điền đáp án bài luyện nghe (Listen & Type) và tự chọn đáp án đúng cho bài Listen & Select trên dailydictation.com. Có chế độ anti-idle giữ cho phút học vẫn cộng khi treo máy.",
  "author": "luongkun",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Trợ lí của Lương",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": ["https://dailydictation.com/*", "https://*.dailydictation.com/*"],
  "content_scripts": [
    {
      "matches": ["https://dailydictation.com/*", "https://*.dailydictation.com/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://dailydictation.com/*", "https://*.dailydictation.com/*"]
    }
  ]
}
